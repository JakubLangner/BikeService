@model BikeService.ViewModels.Login.RegisterVM

@{
    ViewData["Title"] = "Rejestracja";
    Layout = "~/Views/Shared/_LoginLayout.cshtml";
}

<h2 class="text-center">
    Zarejestruj się w serwisie
</h2>

<form asp-action="Register" asp-controller="Login" method="post" class="form-horizontal col-md-12" role="form">

    @*<div asp-validation-summary="All" class="text-danger"></div>*@

    @if (TempData["RegisterError"] != null)
    {
        <div class="text-danger text-center">

            @TempData["RegisterError"]
        </div>
    }

    <div class="form-group">
        <label asp-for="UserName" class="col-md-6 control-label"></label>
        <input asp-for="UserName" class="form-control" />
        <span asp-validation-for="UserName" class="text-danger"></span>
    </div>
    <div class="row">
        <div class="col-md-6">
            <label asp-for="FirstName" class="col-md-4 control-label"></label>
            <input asp-for="FirstName" class="form-control" />
            <span asp-validation-for="FirstName" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="LastName" class="col-md-5 control-label"></label>
            <input asp-for="LastName" class="form-control" />
            <span asp-validation-for="LastName" class="text-danger"></span>
        </div>
    </div>
    <div class="form-group" style="margin-top:5px;">
        <label asp-for="Email" class="col-md-4 control-label"></label>
        <input asp-for="Email" class="form-control" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>
    <div class="row">
        <div class="col-md-6">
            <label asp-for="Password" class="col-md-4 control-label"></label>
            <input asp-for="Password" class="form-control" />
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="ConfirmPassword" class="col-md-9 control-label"></label>
            <input asp-for="ConfirmPassword" class="form-control" />
            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
        </div>
    </div>
    <div class="form-group" style="margin-top:10px">
        <input type="submit" class="btn btn-primary" value="Rejestracja" />
    </div>
</form>
