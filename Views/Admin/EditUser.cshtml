@model BikeService.ViewModels.Admin.UsersViewModel

@{
    ViewData["Title"] = "Edycja użytkownika";
    Layout = "~/Views/Shared/_EditUserLayout.cshtml";
}

<h2 class="text-center">
    Edycja użytkownika
</h2>

<form asp-action="EditUser" asp-controller="Admin" method="post" class="form-horizontal col-md-12" role="form">

    @*<div asp-validation-summary="All" class="text-danger"></div>*@

    <div class="form-group">
        <label asp-for="UserName" class="col-md-6 control-label"></label>
        <input asp-for="UserName" class="form-control" />
        <span asp-validation-for="UserName" class="text-danger"></span>
    </div>
    <div class="row">
        <div class="col-md-6">
            <label asp-for="FirstName" class="col-md-4 control-label"></label>
            <input asp-for="FirstName" class="form-control" />
            <span asp-validation-for="FirstName" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="LastName" class="col-md-5 control-label"></label>
            <input asp-for="LastName" class="form-control" />
            <span asp-validation-for="LastName" class="text-danger"></span>
        </div>
    </div>
    <div class="form-group" style="margin-top:5px;">
        <label asp-for="Email" class="col-md-4 control-label"></label>
        <input asp-for="Email" class="form-control" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>
    <div class="row">
        <div class="form-group col-md-10">
            <label asp-for="Roles" class="col-md-6 control-label"></label>
            @Html.ListBoxFor(m => m.Role, Model.Roles, new { @class = "form-control" })
            @Html.ValidationMessageFor(i => i.Roles,
                "", new { @class = "text-warning" })
        </div>
    </div>
    <div class="form-group" style="margin-top:10px">
        <input type="submit" class="btn btn-primary" value="Edycja" />
        <a asp-action="Users" class="btn btn-danger pull-right">Powrót</a>
    </div>
</form>