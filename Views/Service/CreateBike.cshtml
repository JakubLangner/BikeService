@model BikeService.ViewModels.Service.BikeViewModel

@{
    ViewData["Title"] = "CreateBike";
    Layout = "~/Views/Shared/_ServiceLayout.cshtml";
}

<h1 class="text-center">Dodaj rower</h1>

<hr />
<div class="row ml-2 ml-auto mr-auto">
    <div class="col-md-12">
        <form asp-action="CreateBike">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="row text-center">
                <div class="form-group">
                    <label asp-for="YearOfProduction" class="control-label"></label>
                    <input asp-for="YearOfProduction" class="form-control" />
                    <span asp-validation-for="YearOfProduction" class="text-danger"></span>
                </div>
                <div class="form-group ml-1">
                    <label asp-for="BikeType" class="control-label"></label>
                    <input asp-for="BikeType" class="form-control" />
                    <span asp-validation-for="BikeType" class="text-danger"></span>
                </div>
                <div class="form-group ml-1">
                    <label asp-for="TechnicalCondition" class="control-label"></label>
                    <input asp-for="TechnicalCondition" class="form-control" />
                    <span asp-validation-for="TechnicalCondition" class="text-danger"></span>
                </div>
                <div class="form-group ml-1">
                    <label asp-for="BikeDestiny" class="control-label"></label>
                    <input asp-for="BikeDestiny" class="form-control" />
                    <span asp-validation-for="BikeDestiny" class="text-danger"></span>
                </div>
                <div class="form-group ml-1">
                    <label asp-for="CurrentAdvertisingCampaign" class="control-label"></label>
                    <input asp-for="CurrentAdvertisingCampaign" class="form-control" />
                    <span asp-validation-for="CurrentAdvertisingCampaign" class="text-danger"></span>
                </div>
                <div class="form-group ml-1">
                    <label asp-for="BikeStatus" class="control-label"></label>
                    <br />
                    <select asp-for="BikeStatus" asp-items="Html.GetEnumSelectList<BikeService.Models.Enums.BikeStatus>()">
                        <option selected="selected" value="">Opcje od wybrania:</option>
                    </select>
                </div>
            </div>          
            <div class="form-group">
                <input type="submit" value="Dodaj" class="btn btn-primary" />
                <a asp-action="AllBikes">Powrót</a>
            </div>
        </form>
    </div>
</div>
    


